# =============================================================================
# Lumidoc frontend — environment variables
# =============================================================================
# Vite reads `.env`, `.env.local`, `.env.<mode>` automatically.
# Everything starting with VITE_ is exposed to the client bundle.

# Path used by the axios client. With the Vite dev proxy this can stay relative.
VITE_API_BASE_URL=/api/v1

# Origin used to build absolute URLs (Google OAuth start, EventSource, etc.).
# Leave EMPTY in production when the frontend and API share an origin.
VITE_API_ORIGIN=http://localhost:8000

# Default request timeout for non-streaming, non-upload calls.
VITE_API_TIMEOUT_MS=60000

# Optional: redirect the dev proxy to a different backend (defaults to
# http://localhost:8000). Use http://api:8000 inside docker-compose.
# VITE_DEV_PROXY_TARGET=http://localhost:8000
