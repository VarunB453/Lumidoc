# =============================================================================
# Lumidoc Backend - Environment Variables
# =============================================================================
# Copy to `.env` and fill in your secrets. Keys are loaded from disk in dev
# (auto-generated under ./keys) but should be mounted from a vault in prod.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                 # development | staging | production | test
APP_NAME=Lumidoc
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=please-change-me-to-a-strong-random-string

# CORS — comma-separated list of allowed origins.
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,api.lumidoc.io

# -----------------------------------------------------------------------------
# JWT (RS256 asymmetric)
# -----------------------------------------------------------------------------
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=lumidoc
JWT_AUDIENCE=lumidoc-api

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=lumidoc

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_RATELIMIT_DB=2

# -----------------------------------------------------------------------------
# Storage  (USE_LOCAL_STORAGE=true keeps everything on disk for dev)
# -----------------------------------------------------------------------------
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=lumidoc-files
S3_PRESIGNED_URL_TTL=900            # 15 minutes
MAX_UPLOAD_SIZE_MB=500

# -----------------------------------------------------------------------------
# OpenRouter (chat + embeddings)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Lumidoc
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_EMBEDDING_TIMEOUT_SECONDS=30
LLM_GENERATION_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# OpenAI (Whisper only)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1

# -----------------------------------------------------------------------------
# Vector store
# -----------------------------------------------------------------------------
VECTOR_BACKEND=faiss                # faiss | pinecone
FAISS_INDEX_DIR=./storage/faiss
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=lumidoc
EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# Google OAuth2
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/auth/callback

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_IP=100
RATE_LIMIT_PER_USER=30
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4
CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
